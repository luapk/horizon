# Required
SESSION_SECRET=change-me-to-a-long-random-string
# Pick one: a bcrypt hash (preferred) or a plaintext password (dev only)
AUTH_PASSWORD_HASH=
AUTH_PASSWORD=devpass

# Optional -- omit any of these and the pipeline falls back to a zero-cost
# mock provider for that stage (no network, no spend, structurally valid stubs)
ANTHROPIC_API_KEY=
TAVILY_API_KEY=
VOYAGE_API_KEY=

# Optional spend governance (0 or unset = no cap)
# Block any single scan whose high estimate exceeds this many USD:
MAX_SCAN_USD=0
# Block new scans once this month's committed spend would exceed this many USD:
MONTHLY_BUDGET_USD=0

# Optional overrides
PORT=8787
FRONTEND_ORIGIN=http://localhost:5173
DB_PATH=./horizon.sqlite3
EMBEDDING_PRICE_PER_MTOK=0.06
SEARCH_PRICE_PER_CALL=0.008
